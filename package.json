    "firebase": "^11.10.0",
    "fuse.js": "^7.3.0",
    "gsap": "^3.15.0",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",

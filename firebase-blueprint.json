{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "category": { "type": "string" },
        "badge": { "type": "string" }
      }
    },
    "Client": {
      "title": "Client",
      "description": "ISP or CCTV Customer",
      "type": "object",
      "properties": {
        "id": { "type": "number" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string" },
        "due": { "type": "number" },
        "totalPaid": { "type": "number" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Sales order",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string" }
      }
    },
    "Expense": {
      "title": "Expense",
      "description": "Business expense",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "category": { "type": "string" }
      }
    },
    "Offer": {
      "title": "Offer",
      "description": "Promotional offer",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" }
      }
    },
    "Alert": {
      "title": "Alert",
      "description": "Maintenance or outage alert",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" }
      }
    },
    "Service": {
      "title": "Service",
      "description": "Business service offered",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "imageUrl": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Inventory" },
    "/clients/{clientId}": { "schema": "Client", "description": "Customer base" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Spending" },
    "/offers/{offerId}": { "schema": "Offer", "description": "Marketing" },
    "/alerts/{alertId}": { "schema": "Alert", "description": "Network status" },
    "/services/{serviceId}": { "schema": "Service", "description": "Offered services" },
    "/public_orders/{orderId}": { "schema": "Order", "description": "Incoming sales" },
    "/settings/global": { "schema": "object", "description": "Global config" },
    "/users/{userId}": { "schema": "object", "description": "Legacy user data" }
  }
}

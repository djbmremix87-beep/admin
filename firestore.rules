rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.matches("(?i)itdepartmentpro33@gmail.com") ||
        request.auth.token.email.matches("(?i)djbmremix87@gmail.com")
      );
    }

    // Individual User Data (for migration/backup)
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Products: Anyone can read, only admin can write, anyone can update stock
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      allow update: if true; 
    }

    // Offers: Anyone can read, only admin can write
    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Alerts: Anyone can read, only admin can write
    match /alerts/{alertId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Services: Anyone can read, only admin can write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public Orders: Anyone can create, admin can manage
    match /public_orders/{orderId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin() || (resource.data.status == "pending");
    }

    // Settings
    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Clients & Expenses: Admin only (or anyone for testing if needed, but keeping it admin for now)
    match /clients/{clientId} {
      allow read, write: if isAdmin() || isSignedIn(); 
    }
    match /expenses/{expenseId} {
      allow read, write: if isAdmin();
    }

    // Health check
    match /test/connection {
      allow read: if true;
    }
  }
}
